PORT=5000
DB_HOST=replace_with_sqlserver_name
DB_PORT=1433
DB_NAME=SQLInventory
DB_USER=Invent
DB_PASSWORD=replace_with_real_password

# JWT (HMAC) - generate a long random value (recommended 64+ chars) and keep it private.
JWT_SECRET=replace_with_long_random_secret

# Short-lived access token is recommended unless you also implement refresh tokens. - Default 15m. Change as per requirement.
JWT_EXPIRY=15m

# Optional hardening
JWT_ALGORITHM=HS256
# JWT_ISSUER=inventory-api
# JWT_AUDIENCE=inventory-ui

# IIS / reverse proxy hardening (recommended when hosted behind IIS/ARR)
# TRUST_PROXY=1
# FORCE_HTTPS=1

# CORS hardening (recommended even on intranet)
# CORS_ORIGINS=https://intranet-app.company.local

# Brute-force protection for login (careful with NAT'd intranet users; tune as needed)
# ENABLE_LOGIN_RATE_LIMIT=1
# LOGIN_RATE_WINDOW_MS=900000
# LOGIN_RATE_MAX=30
